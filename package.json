{
  "name": "friday",
  "private": true,
  "version": "0.8.4",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 8735",
    "build": "next build",
    "typecheck": "bun ./node_modules/typescript/lib/tsc.js --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,css,md}\"",
