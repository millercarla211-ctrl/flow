{
  "name": "flow",
  "private": true,
  "version": "0.8.4",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun ./node_modules/vite/bin/vite.js",
    "build": "bun ./node_modules/typescript/lib/tsc.js && bun ./node_modules/vite/bin/vite.js build",
    "typecheck": "bun ./node_modules/typescript/lib/tsc.js --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,css,md}\"",
    "lingui:extract": "lingui extract",
    "lingui:compile": "lingui compile",
    "preview": "bun ./node_modules/vite/bin/vite.js preview",
    "tauri": "node ./scripts/tauri.mjs",
    "lint": "bun ./node_modules/eslint/bin/eslint.js src/"
  },
  "dependencies": {
    "@lingui/core": "^6.0.1",
