{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glimpse",
  "identifier": "com.glimpse.data",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:8735",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Glimpse",
        "width": 300,
        "height": 190,
        "x": -9999,
        "y": -9999,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false,
        "center": false,
        "focus": false,
        "visible": false
      },
      {
        "label": "settings",
        "title": "Glimpse",
        "width": 900,
        "height": 750,
        "minWidth": 900,
        "minHeight": 750,
        "resizable": true,
        "visible": false,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      },
      {
        "label": "toast",
        "title": "Glimpse Toast",
        "width": 420,
        "height": 200,
        "x": 0,
        "y": 0,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false,
        "center": false,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: http://asset.localhost customprotocol:; base-uri 'self'; form-action 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob: https:; connect-src 'self' ipc: http://ipc.localhost https: wss: http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:*",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/library/**",
          "$APPDATA/local/cache/appicons/**",
          "$APPDATA/local/cache/siteicons/**"
        ]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "hardenedRuntime": true,
      "minimumSystemVersion": "14.0",
      "entitlements": "Entitlements.plist",
      "dmg": {
        "windowSize": {
          "width": 720,
          "height": 450
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwRjZFNTY4MTZGNjc3RkQKUldUOWQvWVdhT1gySUtvN0IwSUQxTW8rWitVeHRlMC9FcjZ0TWp6RlVld0ltUnA5QVc2S0N0TVUK",
      "endpoints": [
        "https://github.com/LegendarySpy/Glimpse/releases/latest/download/latest.json"
      ]
    }
  }
}
